{
  "manifestVersion": 1,
  "id": "semgrep-security-scan",
  "version": "1.2.18",
  "name": "Semgrep Security Scan",
  "description": "Comprehensive security scanning with Semgrep including SAST, SCA, and License compliance with configurable ticket creation and auto-fix PR capabilities",
  "publisher": "YashMishrar00thunter",
  "galleryFlags": [
    "Public"
  ],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "icons": {
    "default": "extension/icons/icon.png"
  },
  "contributions": [
    {
      "id": "semgrep-scan-task",
      "type": "ms.vss-distributed-task.task",
      "targets": [
        "ms.vss-distributed-task.tasks"
      ],
      "properties": {
        "name": "semgrepScan"
      }
    },
    {
      "id": "semgrep-hub-group",
      "type": "ms.vss-web.hub-group",
      "description": "Semgrep security scan configuration",
      "targets": [
        "ms.vss-web.project-hub-groups"
      ],
      "properties": {
        "name": "Semgrep",
        "order": 85,
        "icon": "asset://extension/icons/icon.png"
      }
    },
    {
      "id": "semgrep-pipeline-hub",
      "type": "ms.vss-web.hub",
      "targets": [
        "ms.vss-build-web.build-release-hub-group"
      ],
      "properties": {
        "name": "Semgrep Config",
        "order": 95,
        "uri": "semgrepScan/ui/task-inputs.html"
      }
    },
    {
      "id": "semgrep-config-hub",
      "type": "ms.vss-web.hub",
      "targets": [
        "YashMishrar00thunter.semgrep-security-scan.semgrep-hub-group"
      ],
      "properties": {
        "name": "Scan Configuration",
        "order": 1,
        "uri": "semgrepScan/ui/task-inputs.html"
      }
    }
  ],
  "files": [
    {
      "path": "semgrepScan",
      "addressable": true
    },
    {
      "path": "extension/icons",
      "addressable": true
    }
  ],
  "content": {
    "details": {
      "path": "README.md"
    },
    "license": {
      "path": "LICENSE"
    }
  },
  "categories": [
    "Azure Pipelines"
  ],
  "tags": [
    "semgrep",
    "security",
    "sast",
    "sca",
    "license",
    "vulnerability",
    "code-scanning"
  ]
}
