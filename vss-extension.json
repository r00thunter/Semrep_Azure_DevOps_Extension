{
  "manifestVersion": 1,
  "id": "semgrep-security-scan",
  "version": "1.1.7",
  "name": "Semgrep Security Scan",
  "description": "Comprehensive security scanning with Semgrep including SAST, SCA, and License compliance with configurable ticket creation and auto-fix PR capabilities",
  "publisher": "YashMishrar00thunter",
  "galleryFlags": [
    "Public"
  ],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "icons": {
    "default": "extension/icons/icon.png"
  },
  "contributions": [
    {
      "id": "semgrep-scan-task",
      "type": "ms.vss-distributed-task.task",
      "targets": [
        "ms.vss-distributed-task.tasks"
      ],
      "properties": {
        "name": "semgrepScan"
      }
    }
  ],
  "files": [
    {
      "path": "semgrepScan",
      "addressable": true
    },
    {
      "path": "extension/icons",
      "addressable": true
    }
  ],
  "content": {
    "details": {
      "path": "README.md"
    },
    "license": {
      "path": "LICENSE"
    }
  },
  "categories": [
    "Azure Pipelines"
  ],
  "tags": [
    "semgrep",
    "security",
    "sast",
    "sca",
    "license",
    "vulnerability",
    "code-scanning"
  ]
}
