{
  "name": "semgrep-azure-devops-extension",
  "version": "0.1.0",
  "description": "Azure DevOps extension for Semgrep security scanning with ticket creation and auto-fix capabilities",
  "scripts": {
    "build": "tsc && npm run copy-scripts",
    "copy-scripts": "node scripts/copy-scripts.js",
    "prepare-task": "node scripts/prepare-task.js",
    "zip-task": "node scripts/zip-task.js",
    "package": "npm run build && npm run prepare-task && tfx extension create --manifest-globs vss-extension.json",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "semgrep",
    "azure-devops",
    "security",
    "sast",
    "sca",
    "license-compliance"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "tfx-cli": "^0.15.0"
  },
  "dependencies": {
    "azure-pipelines-task-lib": "^4.0.0"
  }
}
